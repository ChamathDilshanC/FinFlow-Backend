# Application
APP_NAME=Subscription Finance Tracker
DEBUG=false

# Database (async SQLAlchemy — use postgresql+asyncpg://)
# Supabase pooler (PgBouncer, transaction mode): use port 6543 and set DATABASE_USE_POOLER=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/postgres
DATABASE_USE_POOLER=false

# Supabase Auth — JWT verification (Dashboard → Project Settings → API)
# Project URL (no trailing slash). JWKS: {SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Optional: Legacy JWT Secret from "Legacy JWT Secret" tab — verifies HS256 tokens during key rotation
# SUPABASE_JWT_LEGACY_HS256_SECRET=
# Optional overrides (defaults match typical Supabase user access tokens):
# SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
# SUPABASE_JWT_AUDIENCE=authenticated

# Logging: console text or JSON (structured)
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS — comma-separated origins for Flutter/web (e.g. http://localhost:8080,http://127.0.0.1:8080)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:8080
