# =============================================================================
# FinFlow backend — .env සියල්ල (copy කරලා .env ලෙස save කරන්න, අගට fill කරන්න)
# -----------------------------------------------------------------------------
# අනිවාර්ය (app එක start වෙන්න): DATABASE_URL, SUPABASE_URL
# විකල්ප නමුත් නිර්දේශිත: SUPABASE_ANON_KEY (/auth/register, /auth/login email routes ට)
# විකල්ප: ඉතිරි සියල්ල — defaults config.py එකේ
# Vercel: මේ keys Dashboard → Environment Variables එකට දාන්න — විස්තර: VERCEL.md
# =============================================================================

# --- Application ---
APP_NAME=Subscription Finance Tracker
DEBUG=false

# --- Database (async SQLAlchemy — ඕනෑවටම postgresql+asyncpg://) ---
# Supabase pooler: port 6543 + DATABASE_USE_POOLER=true
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/postgres
DATABASE_USE_POOLER=false

# --- Supabase ---
# Bearer JWT verify (සියලු API — Email / Google / OAuth ඕනෑම token එකක්)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Email/password backend routes (/api/v1/auth/register, /login) — Dashboard → API → anon public key
SUPABASE_ANON_KEY=

# අමතර (බොහෝ වේලාවට නොදානවා): Legacy JWT Secret — HS256 fallback (key rotation)
# SUPABASE_JWT_LEGACY_HS256_SECRET=

# අමතර: JWT iss/aud — default සාමාන්‍යයෙන් හරි (override ඕන නම් uncomment)
# SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# අමතර: refresh token — දැනට backend එකේ reserved / අනාගතයට
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- CORS (comma-separated) Flutter/web origins ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:8080
